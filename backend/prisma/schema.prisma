generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  name         String?
  phone        String?
  currency     String        @default("RUB")
  balance      Decimal       @default(0)
  bonus        Decimal       @default(0)
  refreshToken String?
  role         UserRole      @default(USER)
  status       UserStatus    @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  games        Game[]
  bets         Bet[]
  transactions Transaction[]
  logs         ActionLog[]
  resetTokens  PasswordReset[]
  kycRequests  KycRequest[]
  supportMessages SupportMessage[]
}

model Game {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  type      String
  bet       Decimal
  win       Decimal
  createdAt DateTime @default(now())
}

model Transaction {
  id        Int               @id @default(autoincrement())
  user      User              @relation(fields: [userId], references: [id])
  userId    Int
  type      TransactionType
  amount    Decimal
  status    TransactionStatus @default(PENDING)
  metadata  Json?
  createdAt DateTime          @default(now())
}

model Bet {
  id           Int            @id @default(autoincrement())
  user         User           @relation(fields: [userId], references: [id])
  userId       Int
  type         BetType
  stake        Decimal
  totalOdds    Decimal
  potentialWin Decimal
  status       BetStatus      @default(PENDING)
  createdAt    DateTime       @default(now())
  settledAt    DateTime?
  selections   BetSelection[]
}

model BetSelection {
  id        Int         @id @default(autoincrement())
  bet       Bet         @relation(fields: [betId], references: [id])
  betId     Int
  event     SportEvent? @relation(fields: [eventId], references: [id])
  eventId   Int?
  eventName String
  market    String
  outcome   String?
  odd       Decimal
}

model SportEvent {
  id        Int           @id @default(autoincrement())
  sport     String
  league    String
  name      String
  startTime DateTime
  status    EventStatus   @default(SCHEDULED)
  isLive    Boolean       @default(false)
  score     String?
  markets   Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  selections BetSelection[]
}

model ActionLog {
  id        Int      @id @default(autoincrement())
  user      User?    @relation(fields: [userId], references: [id])
  userId    Int?
  action    String
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  TRANSFER
  BONUS
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  REJECTED
}

enum BetType {
  SINGLE
  EXPRESS
  SYSTEM
}

enum BetStatus {
  PENDING
  WON
  LOST
  VOID
}

enum EventStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELED
}

model KycRequest {
  id        Int       @id @default(autoincrement())
  user      User      @relation(fields: [userId], references: [id])
  userId    Int
  status    KycStatus @default(PENDING)
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model SupportMessage {
  id        Int         @id @default(autoincrement())
  user      User        @relation(fields: [userId], references: [id])
  userId    Int
  from      SupportFrom
  message   String
  createdAt DateTime    @default(now())
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SupportFrom {
  USER
  ADMIN
}
